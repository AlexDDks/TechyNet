<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script src="https://kit.fontawesome.com/fa36d49c1a.js" crossorigin="anonymous"></script>
    <link rel="stylesheet" href="/styles/profile.css">
    <link rel="stylesheet" href="/styles/header.css">
    <link rel="stylesheet" href="/styles/footer.css">
    <title><%= user.email %></title>
</head>
<body>
    <%- include('partials/header.ejs') %>

    <section class="user">
        <article class="userBox">
            <div class="divImg">
                <img src="/img/users/<%= user.imageUrl %>" alt="User Profile Image">
            </div>
            <div class="userInfo">
                <p class="userName"><%= user.name %></p>
                <p class="userEmail"><%= user.email %></p>
            </div>
            <div class="divButtons">
                <div class="divEdit">
                    <a href="/users/edit/<%= user.id %>" class="buttonEdit">Edit Profile</a>
                </div>
                <%- include('partials/modalDeleteUser.ejs') %>
            </div>
        </article>

        <article class="userHistory">
            <h2>Purchase History</h2>
            <ul>
                <% if (user.purchaseHistory && user.purchaseHistory.length > 0) { %>
                    <% user.purchaseHistory.forEach(purchase => { %>
                        <li>
                            <p>Order ID: <%= purchase.orderId %></p>
                            <p>Date: <%= purchase.date %></p>
                            <p>Total: $<%= purchase.total %></p>
                        </li>
                    <% }) %>
                <% } else { %>
                    <p>No purchase history available.</p>
                <% } %>
            </ul>
        </article>

        <article class="userCart">
            <h2>Shopping Cart</h2>
            <ul>
                <% if (user.cart && user.cart.length > 0) { %>
                    <% user.cart.forEach(item => { %>
                        <li>
                            <p>Product: <%= item.productName %></p>
                            <p>Quantity: <%= item.quantity %></p>
                            <p>Price: $<%= item.price %></p>
                            <a href="/cart/remove/<%= item.productId %>" class="buttonRemove">Remove</a>
                        </li>
                    <% }) %>
                <% } else { %>
                    <p>Your cart is empty.</p>
                <% } %>
            </ul>
        </article>
    </section>

    <%- include('partials/footer.ejs') %>
</body>
</html>
